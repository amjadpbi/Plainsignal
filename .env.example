# ---------------------------------------------------------------------------
# Plainsignal environment — copy to .env.local for local dev, .env for Docker.
# Never commit real secrets. See CLAUDE.md section 2 (Rules).
# ---------------------------------------------------------------------------

# --- Database (Postgres via Prisma) ---
# Use a hosted Postgres (Neon). Copy the connection string from the Neon
# dashboard. Neon requires TLS, so keep sslmode=require.
# Format: postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.REGION.aws.neon.tech/plainsignal?sslmode=require"

# --- Redis (cache + queues) ---
# Optional for local dev: if unset, the app falls back to an in-process cache /
# rate-limit store (single-process only). Set this to a hosted Redis (e.g.
# Upstash) when you need shared caching or run multiple instances.
REDIS_URL=""

# --- Etsy Open API v3 ---
# When unset, the app runs in MOCK MODE: the Etsy client returns deterministic
# synthetic data so the whole keyword pipeline works without a key.
# Set this to your Etsy app keystring to make real, rate-limited API calls.
ETSY_API_KEY=""
# Optional: override the Etsy API base (rarely needed).
ETSY_API_BASE="https://openapi.etsy.com/v3/application"

# --- Etsy rate limits (per CLAUDE.md: 5 req/s, 5000/day) ---
ETSY_RATE_PER_SECOND="5"
ETSY_RATE_PER_DAY="5000"

# --- Cache TTLs (seconds) ---
ETSY_CACHE_TTL_SECONDS="86400"

# --- Supabase Auth (Phase 2) — identity issuer only ---
# From your Supabase project's API settings. The URL is normalized to its
# origin in code, so a trailing /rest/v1/ is tolerated. Anon key is public
# (exposed to the browser); the service-role key is a SECRET — server only.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-or-secret-key"

# --- AI layer (Phase 4) — provider-agnostic ---
# The AI only writes rationale over numbers computed from real data; the
# grounding guard validates its output no matter which provider generated it.
# Leave all keys empty to run in mock mode (metrics stay real, narrative is
# templated).
#
# OpenRouter is the default: OpenAI-compatible, with free models (IDs ending
# in :free) so it needs no paid billing. Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# The free-model lineup rotates, so default to the free auto-router rather
# than pinning a model that may be withdrawn.
OPENROUTER_MODEL="openrouter/free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional alternative provider — requires paid billing.
# Set AI_PROVIDER to "openrouter" or "anthropic" to force one when both keys
# are present; otherwise OpenRouter wins.
AI_PROVIDER=""
ANTHROPIC_API_KEY=""

# --- Stripe (Phase 5 — not used yet) ---
# STRIPE_SECRET_KEY=""

# --- Trademark source (Phase 3) ---
# No official keyless USPTO text-search API exists (TESS retired 2023; TSDR is
# serial-number lookup behind a key; Open Data Portal is bulk data behind a
# USPTO.gov account). Leave BOTH empty to run the trademark module in mock mode.
# Point these at whichever register you have rights to query.
TRADEMARK_API_URL=""
TRADEMARK_API_KEY=""
